{
	"name": "@savvy-web/devcontainer",
	"version": "0.0.0",
	"private": true,
	"description": "Composable devcontainer features designed to work with Savvy Web repos locally and in Codespaces.",
	"homepage": "https://github.com/savvy-web/devcontainers#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/savvy-web/devcontainers.git"
	},
	"license": "MIT",
	"author": {
		"name": "C. Spencer Beggs",
		"email": "spencer@savvyweb.systems",
		"url": "https://savvyweb.systems"
	},
	"type": "module",
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"build": "echo \"No build required\"",
		"build:dev": "echo \"No build required\"",
		"build:inspect": "rslib inspect --config-loader native --env-mode npm --verbose",
		"build:prod": "echo \"No build required\"",
		"ci:build": "CI=\"true\" turbo run build:dev build:prod --log-order=grouped --output-logs=full",
		"ci:test": "CI=\"true\" vitest run --passWithNoTests",
		"ci:version": "savvy changeset version && biome format --write .",
		"feature:test": "bash lib/scripts/test-feature.sh",
		"feature:validate": "bash lib/scripts/validate-feature.sh",
		"lint": "biome check --max-diagnostics=none",
		"lint:fix": "biome check --write --max-diagnostics=none",
		"lint:fix:unsafe": "biome check --write --unsafe --max-diagnostics=none",
		"lint:md": "markdownlint-cli2 '**/*.{md,mdx}' --config './lib/configs/.markdownlint-cli2.jsonc'",
		"lint:md:fix": "markdownlint-cli2  --config './lib/configs/.markdownlint-cli2.jsonc' --fix",
		"prepare": "husky",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest --watch",
		"typecheck": "turbo run types:check --log-prefix=none --log-order=grouped",
		"types:check": "tsgo --noEmit"
	},
	"devDependencies": {
		"@savvy-web/silk": "^1.3.3",
		"@savvy-web/vitest": "^1.6.0"
	},
	"packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
	"engines": {
		"node": ">=24.0.0"
	},
	"devEngines": {
		"packageManager": {
			"name": "pnpm",
			"version": "11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
			"onFail": "ignore"
		},
		"runtime": [
			{
				"name": "node",
				"version": "26.4.0",
				"onFail": "ignore"
			}
		]
	}
}
