{
	"id": "biome",
	"version": "0.1.0",
	"name": "Biome (global linter)",
	"description": "Installs Biome globally for all runtimes. Strict version, reproducible, and idempotent.",
	"documentationURL": "https://github.com/savvy-web/devcontainers/blob/main/src/biome/README.md",
	"options": {
		"biomeVersion": {
			"type": "string",
			"default": "2.4.13",
			"description": "Biome version (absolute, no semver ranges)"
		}
	},
	"installsAfter": [],
	"entrypoint": "/install.sh",
	"keywords": ["biome", "linter", "global", "formatter"],
	"customizations": {
		"vscode": {
			"extensions": ["biome.biome-vscode"],
			"settings": {
				"biome.enabled": true,
				"biome.requireConfiguration": true,
				"suggestInstallingGlobally": false,
				"editor.defaultFormatter": "biomejs.biome",
				"editor.codeActionsOnSave": {
					"source.fixAll.biome": "explicit",
					"source.organizeImports.biome": "explicit"
				},
				"formattingToggle.affects": [
					"editor.formatOnSave",
					"editor.formatOnPaste",
					"editor.formatOnType",
					"editor.codeActionsOnSave"
				],
				"formattingToggle.statusBarText": {
					"formattingEnabled": "Formatting: $(check)",
					"formattingDisabled": "Formatting: $(x)"
				},
				"[javascript]": {
					"editor.defaultFormatter": "biomejs.biome"
				},
				"[typescript]": {
					"editor.defaultFormatter": "biomejs.biome"
				},
				"[json]": {
					"editor.defaultFormatter": "biomejs.biome"
				},
				"[jsonc]": {
					"editor.defaultFormatter": "biomejs.biome"
				},
				"[css]": {
					"editor.defaultFormatter": "biomejs.biome"
				},
				"[graphql]": {
					"editor.defaultFormatter": "biomejs.biome"
				},
				"[html]": {
					"editor.defaultFormatter": "biomejs.biome"
				},
				"github.copilot.chat.codeGeneration.instructions": [
					{
						"text": "This dev container has Biome pre-installed globally. Biome is a high-performance linter and formatter for JavaScript, TypeScript, JSX, TSX, JSON, and CSS. Use `biome check --write` to lint and format simultaneously, `biome format --write` for formatting only, and `biome lint --write` for linting only."
					}
				]
			}
		}
	}
}
